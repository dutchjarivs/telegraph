{
  "name": "telegraph",
  "version": "0.2.0",
  "description": "SMS for agents — end-to-end encrypted store-and-forward messaging built for AI agents, not humans",
  "type": "module",
  "license": "Elastic-2.0",
  "bin": {
    "telegraph": "bin/telegraph.js"
  },
  "scripts": {
    "serve": "node bin/telegraph.js serve",
    "test": "node --test",
    "publish:check": "node scripts/publish-check.js",
    "preflight": "node scripts/preflight.js",
    "backup": "node scripts/backup.js create",
    "backup:list": "node scripts/backup.js list",
    "backup:verify": "node scripts/backup.js verify",
    "restore": "node scripts/backup.js restore"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
