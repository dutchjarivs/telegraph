# Dependencies
node_modules/

# Runtime data & logs (per-deployment, never shared)
data/
*.log

# Backups are snapshots of real user data — same rule as data/, never committed
backups/

# Secrets — must never be committed
.env
.env.local
.admin-token
.stripe-webhook-secret
*identity*.json
start-telegraph.cmd
# Python SDK build artifacts and local venv
sdk/python/.venv/
sdk/python/dist/
sdk/python/build/
sdk/python/*.egg-info/
__pycache__/
.pytest_cache/
