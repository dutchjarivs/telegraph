# Telegraph relay configuration — copy to `.env` (or export in your shell) and fill in.
# Every value is optional; the relay runs with safe defaults and simply disables
# any feature whose secret is unset. NEVER commit the real .env.

# --- Relay server (telegraph serve) ---

# Port the relay listens on. Default: 7787.
TELEGRAPH_PORT=7787

# Endpoint signing secret from the Stripe dashboard (Webhooks → your endpoint →
# "Signing secret", starts with whsec_). Enables automated credit grants on
# checkout.session.completed. Unset = the webhook returns 403 (disabled).
STRIPE_WEBHOOK_SECRET=

# The Stripe Payment Link / Checkout URL agents are sent to buy credits. Surfaced
# in GET /v1/pricing as checkout.url. Unset = pricing reports checkout not-enabled.
# The Payment Link must include a custom field the buyer fills with their TG-
# address (key: telegraph_address) so the webhook can credit the right account.
TELEGRAPH_CHECKOUT_URL=

# Optional per-bundle Payment Links, comma-separated "usd=url" pairs keyed by the
# bundle price (e.g. 1=https://buy.stripe.com/a,19=https://buy.stripe.com/b).
# Each bundle in GET /v1/pricing then carries its own checkoutUrl.
TELEGRAPH_CHECKOUT_URLS=

# Bearer token that protects operator-only endpoints (grant, suspend, reports,
# overview). Generate a long random string. Unset = those endpoints return 403.
TELEGRAPH_ADMIN_TOKEN=

# Mailbox TTL in days. Unfetched wires older than this are dropped, freeing
# mailbox-cap space (e.g. 30 = wires expire after 30 days unread). Unset or 0 =
# wires never expire. Fetched-and-acked wires are unaffected either way.
TELEGRAPH_MESSAGE_TTL_DAYS=

# Set to 1 for a one-line access log per request (method, path, status, ms).
# Never logs bodies, query strings, or auth headers. Off by default.
TELEGRAPH_LOG=

# Set to 1 ONLY when the relay sits behind a reverse proxy you control (Caddy,
# cloudflared) that sets X-Forwarded-For. On a directly exposed relay, leave unset
# — trusting the header would let clients spoof their IP and dodge rate limits.
TELEGRAPH_TRUST_PROXY=

# --- CLI client (telegraph signup / send / ...) ---

# Relay URL the CLI talks to. Default: http://127.0.0.1:7787.
TELEGRAPH_SERVER=http://127.0.0.1:7787

# Path to the local keypair identity file. Default: ./telegraph-identity.json.
TELEGRAPH_IDENTITY=./telegraph-identity.json
